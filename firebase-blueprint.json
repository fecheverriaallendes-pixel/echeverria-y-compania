{
  "entities": {
    "Sale": {
      "title": "Sale",
      "description": "Definition of a sale document in Firestore",
      "type": "object",
      "properties": {
        "numeroVenta": { "type": "number" },
        "fecha": { "type": "string" },
        "cliente": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Pendiente", "Enviado"] },
        "estadoPago": { "type": "string" },
        "medioPago": { "type": "string" },
        "montoAbonado": { "type": "number" },
        "enviado": { "type": "boolean" },
        "datosCompletos": { "type": "boolean" }
      },
      "required": ["numeroVenta", "fecha", "cliente", "total", "status"]
    },
    "StockItem": {
      "title": "StockItem",
      "description": "Definition of a stock item",
      "type": "object",
      "properties": {
        "codigo": { "type": "string" },
        "stockActual": { "type": "number" },
        "imagenUrl": { "type": "string" },
        "especificaciones": { "type": "string" }
      },
      "required": ["codigo", "stockActual"]
    }
  },
  "firestore": {
    "/sales/{saleId}": {
      "schema": { "$ref": "Sale" },
      "description": "Sales collection"
    },
    "/stock/{itemId}": {
      "schema": { "$ref": "StockItem" },
      "description": "Stock collection"
    }
  }
}
